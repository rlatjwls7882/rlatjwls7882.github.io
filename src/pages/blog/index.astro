---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPostCategory, getPostUrl } from '../../utils/post';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="전체글">
  <h1>전체글</h1>

  <div class="post-list">
    {posts.map((post) => (
      <article class="post-card">
        <a href={getPostUrl(post.id)}>
          <h2>{post.data.title}</h2>

          <div class="meta">
            <span>{post.data.category ?? getPostCategory(post.id)}</span>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('ko-KR')}
            </time>
          </div>

          <div class="tags">
            {post.data.tags.map((tag) => <span>#{tag}</span>)}
          </div>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>