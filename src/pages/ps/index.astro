---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { list } from './list'
---

<BaseLayout title="C++로 하는 PS">
  <section>
    <div class="ps">
      <h1>C++로 하는 PS</h1>

      <table>
        <thead>
          <tr>
            <th>분류</th>
            <th>글</th>
          </tr>
        </thead>
        <tbody>
          {list.map((item) => (
            <tr>
              <td>{item.category}</td>
              <td>
                <a href={`blog/cpp-algorithm/${item.slug}`}>{item.title}</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>