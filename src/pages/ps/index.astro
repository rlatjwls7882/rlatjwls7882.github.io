---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getPostUrl } from '../../utils/post'
import { list } from './list'

const posts = await getCollection('blog', ({ data }) => !data.draft)

const getCppPostKey = (id: string) => {
  const slug = id
    .replace(/\\/g, '/')
    .replace(/\.(md|mdx)$/, '')
    .replace(/\/index$/, '')

  const [root, path, name] = slug.split('/')

  if (root?.toLowerCase().replace(/\s+/g, '-') !== 'cpp-algorithm') return null
  if (!path || !name) return null

  return `${path}/${name}`
}

const postByKey = new Map<string, typeof posts[number]>()

for (const post of posts) {
  const key = getCppPostKey(post.id)
  if (key) postByKey.set(key, post)
}

const groups = list.map((group) => ({
  ...group,
  items: group.items.map((slug) => {
    const post = postByKey.get(`${group.path}/${slug}`)

    return {
      slug,
      title: post?.data.title ?? slug,
      url: post ? getPostUrl(post.id) : `/blog/cpp-algorithm/${group.path}/${slug}`,
      category: post?.data.tags[0] ?? '',
    }
  }),
}))
---

<BaseLayout title="C++로 하는 PS">
  <section>
    <div class="ps">
      <h1>C++로 하는 PS</h1>

      {groups.map((group) => (
        <section>
          <h2>{group.title}</h2>

          <table>
            <thead>
              <tr>
                <th>분류</th>
                <th>글</th>
              </tr>
            </thead>

            <tbody>
              {group.items.map((item) => (
                <tr>
                  <td>{item.category}</td>
                  <td>
                    <a href={item.url}>
                      {item.title}
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>