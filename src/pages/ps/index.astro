---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getPostUrl } from '../../utils/post'
import { list } from './list'

const posts = await getCollection('blog', ({ data }) => !data.draft)

const postByUrl = new Map(
  posts.map((post) => [getPostUrl(post.id), post]),
)

const groups = list.map((group) => ({
  ...group,
  items: group.items.map((item) => {
    const url = `/blog/cpp-algorithm/${item.slug}`

    return {
      ...item,
      url,
      category: postByUrl.get(url)?.data.tags[0] ?? '',
    }
  }),
}))
---

<BaseLayout title="C++로 하는 PS">
  <section>
    <div class="ps">
      <h1>C++로 하는 PS</h1>

      {groups.map((group) => (
        <section>
          <h2>{group.title}</h2>

          <table>
            <thead>
              <tr>
                <th>분류</th>
                <th>글</th>
              </tr>
            </thead>

            <tbody>
              {group.items.map((item) => (
                <tr>
                  <td>{item.category}</td>
                  <td>
                    <a href={item.url}>
                      {item.title}
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>