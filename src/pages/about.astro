---
import BaseLayout from '../layouts/BaseLayout.astro';

const tabs = [
  { id: 'home', label: '홈' },
  { id: 'career', label: '이력' },
  { id: 'contests', label: '대회 참가' },
  { id: 'operations', label: '대회 운영' },
];
---

<BaseLayout
  title="About | rlatjwls7882"
  description="Seojin Kim의 이력, 대회 참가, 대회 운영 기록입니다."
>
  <section class="about-page">
    <h1>소개</h1>

    <div class="about-tabs" aria-label="About page navigation">
      {tabs.map((tab, index) => (
        <a
          class:list={['about-tab', { active: index === 0 }]}
          href={`#${tab.id}`}
          data-about-tab={tab.id}
        >
          {tab.label}
        </a>
      ))}
    </div>

    <section id="home" class="about-section active" data-about-panel="home">
      <h2>김서진 (Seojin Kim)</h2>

      <ul>
        <li>(2024 - ) 세종대학교 컴퓨터공학과</li>
        <li>(2020 - 2022) 광주중앙고등학교</li>
      </ul>

      <h3>연락처 / 프로필</h3>
      <ul>
        <li>Email: rlatjwls7882@gmail.com</li>
        <li>GitHub: <a href="https://github.com/rlatjwls7882" target="_blank">rlatjwls7882</a></li>
        <li>Discord: <a href="https://discord.com/users/686075131239465005" target="_blank">rlatjwls7882</a></li>
      </ul>

      <h3>PS 프로필</h3>
      <ul>
        <li>BOJ: <a href="https://www.acmicpc.net/user/rlatjwls3333" target="_blank">rlatjwls3333</a></li>
        <li>solved.ac: <a href="https://solved.ac/profile/rlatjwls3333" target="_blank">rlatjwls3333</a></li>
        <li>Codeforces: <a href="https://codeforces.com/profile/rlatjwls7882" target="_blank">rlatjwls7882</a></li>
        <li>AtCoder: <a href="https://atcoder.jp/users/rlatjwls7882" target="_blank">rlatjwls7882</a></li>
        <li>대회 기록: <a href="https://clist.by/coder/rlatjwls7882" target="_blank">clist.by/coder/rlatjwls7882</a></li>
      </ul>

      <h3>기타</h3>
      <ul>
        <li>...</li>
      </ul>
    </section>

    <section id="career" class="about-section" data-about-panel="career">
      <h2>이력</h2>

      <h3>학력</h3>
      <ul>
        <li>(2024 - ) 세종대학교 컴퓨터공학과</li>
        <li>(2020 - 2022) 광주중앙고등학교 졸업</li>
      </ul>

      <h3>대회 참가</h3>
      <ul>
        <li>
          <strong>국제 대학생 프로그래밍 경시대회(ICPC)</strong>
          <ul>
            <li>2025 ICPC Asia Seoul Regional 본선 진출</li>
            <li>2024 ICPC Asia Seoul Regional 본선 진출</li>
          </ul>
        </li>
        <li>
          <strong>세종대학교 교내 대회(TOSC)</strong>
          <ul>
            <li>2025 제10회 SW코딩경시대회 대상</li>
            <li>2024 제9회 SW코딩경시대회 3등상</li>
          </ul>
        </li>
        <a class="about-more-link" href="#contests">전체 보기</a>
      </ul>

      <h3>대회 운영</h3>
      <ul>
        <li>
          <strong>문제 출제 및 검수</strong>
          <ul>
            <li>2025 건국대학교 프로그래밍 경진대회 (KUPC) 문제 검수</li>
            <li>2026 부산대학교 프로그래밍 대회 (PNUPC) 문제 검수</li>
            <a class="about-more-link" href="#operations">전체 보기</a>
          </ul>
        </li>
      </ul>
    </section>

    <section id="contests" class="about-section" data-about-panel="contests">
      <h2>대회 참가</h2>
      <ul>
        <li>
          <strong>국제 대학생 프로그래밍 경시대회(ICPC)</strong>
          <ul>
            <li>2025 ICPC Asia Seoul Regional 본선 진출</li>
            <li>2024 ICPC Asia Seoul Regional 본선 진출</li>
          </ul>
        </li>
        <li>
          <strong>세종대학교 교내 대회(TOSC)</strong>
          <ul>
            <li>2025 제10회 SW코딩경시대회 대상</li>
            <li>2024 제9회 SW코딩경시대회 3등상</li>
          </ul>
        </li>
      </ul>
    </section>

    <section id="operations" class="about-section" data-about-panel="operations">
      <h2>대회 운영</h2>
      <ul>
        <li>
          <strong>문제 출제 및 검수</strong>
          <ul>
            <li>2025 건국대학교 프로그래밍 경진대회 (KUPC) 문제 검수</li>
            <li>2026 부산대학교 프로그래밍 대회 (PNUPC) 문제 검수</li>
            <li>4개 추가로 검수중</li>
          </ul>
        </li>
      </ul>
    </section>
  </section>

  <script>
    const tabs = document.querySelectorAll('[data-about-tab]');
    const panels = document.querySelectorAll('[data-about-panel]');
    const validTabs = new Set(Array.from(tabs).map((tab) => tab.getAttribute('data-about-tab')));

    const activateTab = (tabId) => {
      const selectedTab = validTabs.has(tabId) ? tabId : 'home';

      tabs.forEach((tab) => {
        tab.classList.toggle('active', tab.getAttribute('data-about-tab') === selectedTab);
      });

      panels.forEach((panel) => {
        panel.classList.toggle('active', panel.getAttribute('data-about-panel') === selectedTab);
      });
    };

    const activateFromHash = () => {
      activateTab(window.location.hash.replace('#', '') || 'home');
    };

    window.addEventListener('hashchange', activateFromHash);
    activateFromHash();
  </script>
</BaseLayout>